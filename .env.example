# 后端 API 地址
VITE_BACKEND_BASE_URL=/backend

# Adapter 服务地址
VITE_ADAPTER_BASE_URL=

# CopilotKit 配置
VITE_COPILOTKIT_PUBLIC_KEY=

# Supabase 配置
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_AUTH_URL=

# Cloudflare Turnstile CAPTCHA（与 Supabase Dashboard 配置配对使用）
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# 代理配置（生产环境使用 HTTPS）
VITE_BACKEND_PROXY_TARGET=https://localhost
VITE_ADAPTER_PROXY_TARGET=https://localhost

# 服务配置
SERVICE_BASE_URL=https://your-domain.com
SERVICE_ADAPTER_PORT=4000

# Adapter 数据库路径
SERVICE_ADAPTER_SQLITE_PATH=server/adapter/data/copilotkit-runtime.sqlite