{
  "name": "agent-workbench-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "repair:deps": "node scripts/repair-copilotkit-dev-entries.mjs",
    "dev": "npm run repair:deps && concurrently \"node scripts/start-adapter.mjs\" \"vite\"",
    "dev:client": "npm run repair:deps && vite",
    "dev:server": "node --env-file=.env server/adapter/serviceAdapter.js",
    "build": "npm run repair:deps && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ag-ui/agno": "^0.0.3",
    "@ant-design/icons": "^6.1.0",
    "@ant-design/x": "^2.2.2",
    "@copilotkit/react-core": "^1.57.1",
    "@copilotkit/react-ui": "^1.57.1",
    "@copilotkit/runtime": "^1.57.1",
    "@copilotkit/sqlite-runner": "^1.57.1",
    "@supabase/supabase-js": "^2.49.8",
    "ahooks": "^3.9.6",
    "antd": "^6.3.3",
    "better-sqlite3": "^12.2.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.19",
    "express": "^5.1.0",
    "jotai": "^2.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.3",
    "remark-gfm": "^4.0.1",
    "scheduler": "^0.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
